---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PostCover from '../components/PostCover.astro';

const posts = await getCollection('posts');
---

<Layout title="chiamamial//note - Feed Industriale">

  <!-- Hero Section -->
  <section class="mb-12 md:mb-24 relative border-b border-[#333] pb-8 md:pb-12 pt-8 md:pt-0">
    <div class="hero-number absolute top-0 right-0 text-[#333] text-6xl md:text-9xl font-dot font-bold opacity-10 pointer-events-none select-none -z-10">
      001
    </div>
    
    <div class="hero-badge inline-block status-badge">
      Diario di Bordo: Attivo
    </div>

    <h1 class="hero-title text-4xl sm:text-6xl md:text-8xl font-bitcount font-bold uppercase leading-none mb-4 md:mb-6 text-white tracking-wide break-words">
      Appunti <br/>
      <span class="text-transparent stroke-text hover:text-[#ff4d00] transition-colors duration-500">Digitali</span> <br/>
      & Tech
    </h1>
    
    <p class="hero-desc text-gray-400 max-w-xl text-xs md:text-base leading-relaxed border-l-2 border-[#ff4d00] pl-4 md:pl-6 py-2 mb-6 md:mb-8 font-mono">
      // Non sono un giornalista. Non sono un guru.
      <br class="hidden sm:block"/>
      // Questo è solo il mio spazio personale dove raccolgo ciò che mi colpisce: tecnologia, innovazione e cultura digitale.
    </p>
  </section>

  <!-- Content Grid -->
  <section>
    <div class="flex items-end justify-between mb-8 md:mb-12 border-b border-[#333] pb-4">
      <h2 class="text-xl md:text-3xl font-bitcount uppercase text-white tracking-widest">
        <span class="text-[#ff4d00] mr-2">/</span> Log
      </h2>
      <a href="/archive" class="text-[10px] md:text-xs font-mono text-gray-500 hover:text-[#ff4d00] uppercase tracking-widest">
        [ Vedi_Tutti ]
      </a>
    </div>

    <div class="grid gap-6 md:gap-8 md:grid-cols-2 lg:grid-cols-3">
      {posts.map(post => (
        <article class="card-article group flex flex-col h-full">
          <a href={`/posts/${post.slug}`} class="flex flex-col h-full">
            <!-- Cover Image Area -->
            <div class="h-48 w-full border-b border-[#333] relative overflow-hidden">
              <PostCover seed={post.slug} />
            </div>

            <div class="p-6 flex flex-col flex-grow">
              <div class="flex justify-between items-start mb-6 text-xs font-mono text-gray-500 uppercase">
                <span class="tag-outline">
                  {post.data.tags[0] || 'NULL'}
                </span>
                <span>{post.data.pubDate.toLocaleDateString('it-IT')}</span>
              </div>
              
              <h3 class="text-2xl font-bitcount font-bold text-white mb-4 group-hover:text-[#ff4d00] transition-colors uppercase leading-tight tracking-wide">
                {post.data.title}
              </h3>
              
              <p class="text-gray-500 text-sm font-mono mb-8 flex-grow leading-relaxed">
                {post.data.description}
              </p>

              <div class="btn-text mt-auto">
                Leggi_File <span>-></span>
              </div>
            </div>
            
            <!-- Corner Decorations -->
            <div class="card-corner-tr"></div>
            <div class="card-corner-bl"></div>
          </a>
        </article>
      ))}
      
      <!-- Placeholder Card -->
      <article class="card-placeholder group">
        <div class="text-center">
          <div class="text-4xl text-[#333] mb-2 font-bitcount font-bold">404</div>
          <div class="text-xs font-mono text-gray-600 uppercase">Dati_Corrotti</div>
        </div>
      </article>
    </div>
  </section>
</Layout>

<style>
  .stroke-text {
    -webkit-text-stroke: 1px #fff;
  }
  .stroke-text:hover {
    -webkit-text-stroke: 1px #ff4d00;
  }
</style>
