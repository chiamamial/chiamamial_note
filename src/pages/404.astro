---
import Layout from '../layouts/Layout.astro';
import HeroBackground from '../components/HeroBackground.astro';
---

<Layout title="404 - Dati Corrotti">
  <div class="relative min-h-[70vh] flex flex-col items-center justify-center text-center overflow-hidden border border-[#333] m-4 md:m-8">
    
    <HeroBackground />

    <div class="relative z-20 p-8 bg-black/40 backdrop-blur-md border border-[#333] max-w-lg w-full">
      <div class="text-[#ff4d00] text-9xl font-bitcount font-bold mb-4 animate-pulse">
        404
      </div>
      
      <div class="inline-block border border-[#ff4d00] text-[#ff4d00] px-4 py-2 text-sm font-bold uppercase mb-6 tracking-widest font-dot bg-black/80">
        Errore Sistema: Dati Mancanti
      </div>
      
      <h1 class="text-2xl md:text-3xl font-bold text-white uppercase mb-6 font-bitcount">
        Pagina Non Trovata
      </h1>
      
      <p class="text-gray-400 font-mono text-sm mb-8 leading-relaxed">
        // Il file richiesto non esiste nel registro. <br/>
        // Potrebbe essere stato spostato o corrotto.
      </p>

      <a href="/" class="btn-outline bg-black hover:bg-[#ff4d00] hover:text-black">
        [ Ritorna alla Base ]
      </a>
    </div>

    <!-- Decorative Corners -->
    <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-[#ff4d00]"></div>
    <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-[#ff4d00]"></div>
    <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-[#ff4d00]"></div>
    <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-[#ff4d00]"></div>
  </div>
</Layout>
